{
  "name": "karali-restaurant-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @karali/backend prisma generate",
    "db:migrate": "pnpm --filter @karali/backend prisma migrate deploy",
    "db:seed": "pnpm --filter @karali/backend prisma db seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "cypress": "^14.5.4",
    "eslint": "^9.33.0",
    "prettier": "^3.6.2",
    "turbo": "^2.4.0",
    "typescript": "^5.8.3"
  }
}
